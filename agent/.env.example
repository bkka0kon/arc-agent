# ─── Arc Agentic · Orchestrator agent · config ───
# Copy this file to ".env" and fill in. NEVER paste a private key here.

# Payment mode:
#   demo = no real payment; 402 responses are skipped (good for seeing the flow)
#   real = pay USDC via the Circle CLI (`circle services pay`) — see docs/SETUP.md §5/§7
PAY_MODE=demo

# Required when PAY_MODE=real. Public 0x... address of your Agent Wallet
# (NOT a private key). Create + fund via Circle CLI (docs/SETUP.md §3–4).
AGENT_WALLET_ADDRESS=

# Chain id for the Circle CLI (default ARC-TESTNET).
CHAIN=ARC-TESTNET

# Service URLs. For local testing, leave blank → defaults to http://localhost:3000.
# When you have real services live, point each to its own domain.
SVC_PRICE=
SVC_DEX=
SVC_SENTIMENT=
SVC_NEWS=
SVC_FLOW=
SVC_SEARCH=
SVC_INFER=
SVC_CHAIN=
SVC_RISK=
SVC_DEFI=
