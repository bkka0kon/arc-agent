# ─── Arc Agentic · Seller API · config ───
# Copy this file to ".env" and fill in your values.
# DO NOT commit the real .env to git. NEVER paste a private key into any chat.

# Wallet address that RECEIVES revenue (public 0x... address, NOT a private key).
# Generate one via Circle CLI: `circle wallet create` (see docs/SETUP.md).
SELLER_WALLET_ADDRESS=0xYOUR_SELLER_WALLET_ADDRESS_HERE

# Port the server listens on (default 3000)
PORT=3000

# Optional: override the x402 facilitator URL. Defaults to Circle's
# hosted testnet facilitator. Confirm the current URL in Circle Console.
# FACILITATOR_URL=https://gateway-api-testnet.circle.com
